<Window x:Class="AppDictionnaire.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AppDictionnaire"
        mc:Ignorable="d"
        Title="Générateur de Dictionnaire (TP1)" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Min Length -->
            <RowDefinition Height="Auto"/> <!-- Max Length -->
            <RowDefinition Height="Auto"/> <!-- Charset Label -->
            <RowDefinition Height="Auto"/> <!-- Checkboxes -->
            <RowDefinition Height="Auto"/> <!-- Custom Chars -->
            <RowDefinition Height="Auto"/> <!-- File Path -->
            <RowDefinition Height="*"/>    <!-- Spacer -->
            <RowDefinition Height="Auto"/> <!-- Generate Button -->
            <RowDefinition Height="Auto"/> <!-- Progress -->
            <RowDefinition Height="Auto"/> <!-- Status -->
        </Grid.RowDefinitions>
        
        <Grid.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,10,10,10"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="5"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style TargetType="CheckBox">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Margin" Value="0,0,20,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </Grid.Resources>

        <!-- Min Length -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Longueur Minimale :" Width="200"/>
            <TextBox Text="{Binding MinLength}" Width="100"/>
        </StackPanel>

        <!-- Max Length -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Longueur Maximale :" Width="200"/>
            <TextBox Text="{Binding MaxLength}" Width="100"/>
        </StackPanel>

        <!-- Charset Header -->
        <TextBlock Grid.Row="2" Text="Caractères permis :" FontWeight="Bold"/>

        <!-- Checkboxes -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="220,0,0,20">
            <CheckBox Content="a-z" IsChecked="{Binding UseLowerCase}"/>
            <CheckBox Content="A-Z" IsChecked="{Binding UseUpperCase}"/>
            <CheckBox Content="0-9" IsChecked="{Binding UseNumbers}"/>
            <CheckBox Content="Spécial" IsChecked="{Binding UseSpecial}"/>
        </StackPanel>

        <!-- Custom Chars -->
        <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Chaîne personnalisée :" Width="200"/>
                <TextBox Text="{Binding CustomChars, UpdateSourceTrigger=PropertyChanged}" Width="400"/>
            </StackPanel>
            <TextBlock Text="(Si rempli, remplace les cases cochées)" Foreground="Gray" FontSize="12" Margin="220,0,0,0"/>
        </StackPanel>

        <!-- Output File -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Fichier de sortie :" Width="200"/>
            <TextBox Text="{Binding OutputPath}" Width="400" IsReadOnly="True"/>
            <Button Content="..." Command="{Binding BrowseCommand}" Width="50" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Generate Button -->
        <Button Grid.Row="7" Content="Générer le Dictionnaire" Command="{Binding GenerateCommand}" 
                Height="50" Width="400" Margin="0,20" Background="LightSkyBlue" FontSize="16" FontWeight="Bold"/>

        <!-- Progress Bar -->
        <ProgressBar Grid.Row="8" Height="30" Value="{Binding ProgressValue}" Maximum="100" Margin="0,10"/>

        <!-- Status Label -->
        <TextBlock Grid.Row="9" Text="{Binding StatusMessage}" HorizontalAlignment="Center" FontStyle="Italic"/>

    </Grid>
</Window>
